{
  "manifest": {
    "name": "zynsearch",
    "version": "1.0.0",
    "description": "Plug-and-play search engine"
  },
  "runtime": {
    "host": "127.0.0.1",
    "port": 7777,
    "protocol": "tcp",
    "output_format": "text",
    "query": null
  },
  "ingestion": {
    "mode": "localdir",
    "corpus_dir": "./test_corpus",
    "s3_bucket": null,
    "s3_prefix": null
  },
  "storage": {
    "db_path": "index.bin"
  },
  "distribution": {
    "channels": [
      "tcp"
    ]
  },
  "cleanup": {
    "enable_periodic_cleanup": true,
    "period_seconds": 60
  },
  "env_path": null,
  "config_path": "zynsearch.config.json"
}
